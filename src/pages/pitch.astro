---
import '../styles/global.css';
---

<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>All Elite — Investor Pitch Deck</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Inter:wght@300;400;500;600;700&family=Big+Shoulders+Display:wght@600;700;800;900&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
<link rel="icon" type="image/svg+xml" href="/chevron.svg">
<style>
/* ── LANGUAGE TOGGLE ── */
body.lang-pt .en-text { display: none !important; }
body:not(.lang-pt) .pt-text { display: none !important; }

.lang-toggle {
  display: flex; align-items: center; gap: 0;
  background: none; border: 1px solid var(--line-2);
  cursor: pointer; overflow: hidden; flex-shrink: 0;
}
.lt-opt {
  font-family: 'JetBrains Mono', monospace;
  font-size: 9px; letter-spacing: 0.2em; text-transform: uppercase;
  padding: 7px 12px; color: var(--muted-2); transition: color .15s, background .15s;
  border: none; background: none; cursor: pointer;
}
.lt-opt.active { color: var(--gold); background: rgba(184,151,50,0.08); }
.lt-sep { color: var(--line-2); font-size: 10px; pointer-events: none; }

/* ── PITCH TABLE ── */
.pitch-table {
  width: 100%; border: 1px solid var(--line);
  border-collapse: collapse; margin-bottom: 24px;
}
.pitch-table th {
  background: var(--bg-2); padding: 13px 20px;
  font-family: 'JetBrains Mono', monospace; font-size: 9px;
  letter-spacing: 0.22em; text-transform: uppercase; color: var(--muted-2);
  text-align: left; border-bottom: 1px solid var(--line); border-right: 1px solid var(--line);
}
.pitch-table th:last-child { border-right: none; }
.pitch-table td {
  padding: 13px 20px; font-size: 13px; color: var(--text);
  border-bottom: 1px solid var(--line); border-right: 1px solid var(--line);
  vertical-align: top; line-height: 1.55;
}
.pitch-table td:last-child { border-right: none; }
.pitch-table tr:last-child td { border-bottom: none; }
.pitch-table tr.total-row td {
  background: var(--bg-2);
  font-family: 'Anton', sans-serif; font-size: 15px;
  letter-spacing: 0.04em; text-transform: uppercase; color: var(--gold);
}
.pitch-table .muted-td { color: var(--muted); }
.pitch-table .gold-td { color: var(--gold); }

/* ── TEXT BLOCKS ── */
.text-block {
  font-size: 15px; color: var(--text);
  line-height: 1.75; max-width: 720px; margin-bottom: 28px;
}
.text-block p { margin-bottom: 14px; }
.text-block p:last-child { margin-bottom: 0; }
.text-block strong { color: var(--gold); }
.text-block em { color: var(--muted); font-style: italic; }

.pitch-quote {
  border-left: 3px solid var(--gold);
  padding: 20px 28px; background: var(--bg-2);
  margin: 24px 0; font-size: 15px; color: var(--muted);
  line-height: 1.65; font-style: italic;
}

/* ── COMPARE TABLE ── */
.compare-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  border: 1px solid var(--line); margin-bottom: 24px;
}
.cg-head {
  padding: 13px 20px; background: var(--bg-2);
  font-family: 'JetBrains Mono', monospace; font-size: 9px;
  letter-spacing: 0.2em; text-transform: uppercase; color: var(--muted-2);
  border-bottom: 1px solid var(--line); border-right: 1px solid var(--line);
}
.cg-head:last-child { border-right: none; }
.cg-head.gold { color: var(--gold); }
.cg-cell {
  padding: 13px 20px; font-size: 13px; color: var(--muted);
  border-bottom: 1px solid var(--line); border-right: 1px solid var(--line); line-height: 1.5;
}
.cg-cell:last-child { border-right: none; }
.cg-cell.em { color: var(--text); font-weight: 500; }
.compare-grid > *:nth-last-child(-n+2) { border-bottom: none; }

/* ── CHANNEL LIST ── */
.channel-list { border: 1px solid var(--line); margin-bottom: 24px; }
.ch-row {
  display: grid; grid-template-columns: 180px 1fr;
  border-bottom: 1px solid var(--line);
}
.ch-row:last-child { border-bottom: none; }
.ch-name {
  padding: 18px 22px; background: var(--bg-2);
  border-right: 1px solid var(--line);
  font-family: 'Anton', sans-serif; font-size: 13px;
  letter-spacing: 0.04em; text-transform: uppercase;
  display: flex; align-items: center;
}
.ch-desc {
  padding: 18px 22px; font-size: 13px;
  color: var(--muted); line-height: 1.55; display: flex; align-items: center;
}
@media (max-width: 600px) {
  .ch-row { grid-template-columns: 1fr; }
  .ch-name { border-right: none; border-bottom: 1px solid var(--line); }
}

/* ── TEAM LIST ── */
.team-list { border: 1px solid var(--line); margin-bottom: 24px; }
.tm-row {
  display: grid; grid-template-columns: 220px 1fr;
  border-bottom: 1px solid var(--line);
}
.tm-row:last-child { border-bottom: none; }
.tm-role {
  padding: 20px 24px; background: var(--bg-2);
  border-right: 1px solid var(--line);
  font-family: 'Anton', sans-serif; font-size: 13px;
  letter-spacing: 0.04em; text-transform: uppercase;
  display: flex; align-items: center;
}
.tm-desc {
  padding: 20px 24px; font-size: 13px;
  color: var(--muted); line-height: 1.55; display: flex; align-items: center;
}
@media (max-width: 600px) {
  .tm-row { grid-template-columns: 1fr; }
  .tm-role { border-right: none; border-bottom: 1px solid var(--line); }
}

/* ── ROADMAP ── */
.roadmap { border: 1px solid var(--line); margin-bottom: 24px; }
.rm-row {
  display: grid; grid-template-columns: 200px 160px 1fr;
  border-bottom: 1px solid var(--line); align-items: start;
}
.rm-row:last-child { border-bottom: none; }
.rm-row.hdr { background: var(--bg-2); }
.rm-row.hdr > * {
  font-family: 'JetBrains Mono', monospace; font-size: 9px;
  letter-spacing: 0.22em; text-transform: uppercase; color: var(--muted-2);
  padding: 11px 18px; border-right: 1px solid var(--line);
}
.rm-row.hdr > *:last-child { border-right: none; }
.rm-phase {
  padding: 18px; font-family: 'Anton', sans-serif;
  font-size: 13px; letter-spacing: 0.04em; text-transform: uppercase;
  border-right: 1px solid var(--line);
}
.rm-time {
  padding: 18px; font-family: 'JetBrains Mono', monospace;
  font-size: 10px; letter-spacing: 0.12em; color: var(--gold);
  text-transform: uppercase; border-right: 1px solid var(--line);
}
.rm-milestone {
  padding: 18px; font-size: 13px;
  color: var(--muted); line-height: 1.5;
}
@media (max-width: 700px) {
  .rm-row { grid-template-columns: 1fr; }
  .rm-row.hdr { display: none; }
  .rm-phase, .rm-time { border-right: none; border-bottom: 1px solid var(--line); }
}

/* ── INVESTOR RECEIVES ── */
.inv-list { border: 1px solid var(--line); margin-bottom: 24px; }
.inv-item {
  padding: 16px 24px; border-bottom: 1px solid var(--line);
  display: flex; gap: 14px; align-items: flex-start;
  font-size: 14px; color: var(--text); line-height: 1.55;
}
.inv-item:last-child { border-bottom: none; }
.inv-item::before { content: '—'; color: var(--gold); flex-shrink: 0; font-family: 'JetBrains Mono', monospace; }

/* ── METRICS GRID ── */
.metrics-grid {
  display: grid; grid-template-columns: repeat(4, 1fr);
  border: 1px solid var(--line); margin-bottom: 24px;
}
.mg-cell {
  padding: 28px 20px; border-right: 1px solid var(--line);
  border-bottom: 1px solid var(--line); background: var(--bg-2);
}
.mg-cell:nth-child(4n) { border-right: none; }
.mg-cell:nth-last-child(-n+4) { border-bottom: none; }
.mg-label {
  font-family: 'JetBrains Mono', monospace; font-size: 8px;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--muted-2); margin-bottom: 10px;
}
.mg-value {
  font-family: 'Big Shoulders Display', sans-serif;
  font-weight: 900; font-size: 28px; color: var(--line-2); line-height: 1;
}
@media (max-width: 700px) {
  .metrics-grid { grid-template-columns: 1fr 1fr; }
  .mg-cell:nth-child(4n) { border-right: 1px solid var(--line); }
  .mg-cell:nth-child(2n) { border-right: none; }
  .mg-cell:nth-last-child(-n+4) { border-bottom: 1px solid var(--line); }
  .mg-cell:nth-last-child(-n+2) { border-bottom: none; }
}

/* ── FUNNEL ── */
.funnel {
  display: flex; border: 1px solid var(--line);
  margin-bottom: 24px; flex-wrap: wrap;
}
.fn-step {
  flex: 1; min-width: 120px; padding: 28px 16px;
  text-align: center; border-right: 1px solid var(--line);
}
.fn-step:last-child { border-right: none; }
.fn-num {
  font-family: 'Big Shoulders Display', sans-serif;
  font-weight: 900; font-size: 48px; color: var(--line-2); line-height: 1; margin-bottom: 10px;
}
.fn-label {
  font-family: 'JetBrains Mono', monospace; font-size: 9px;
  letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); margin-bottom: 6px;
}
.fn-desc { font-size: 12px; color: var(--muted); line-height: 1.5; }
@media (max-width: 600px) {
  .funnel { flex-direction: column; }
  .fn-step { border-right: none; border-bottom: 1px solid var(--line); }
  .fn-step:last-child { border-bottom: none; }
}

/* ── EQUITY NOTE ── */
.equity-note {
  background: var(--bg-2); border: 1px solid var(--line);
  padding: 18px 24px; margin-top: -16px; margin-bottom: 24px;
  font-size: 12px; color: var(--muted); line-height: 1.65; font-style: italic;
}

/* ── BACK COVER ── */
.back-cover {
  background: var(--bg-2); padding: 120px 0 100px;
  border-top: 1px solid var(--line); text-align: center;
}
.bc-logo { color: var(--gold); width: 120px; height: 120px; margin: 0 auto 40px; }
.bc-title {
  font-family: 'Anton', sans-serif; font-size: clamp(48px, 8vw, 96px);
  letter-spacing: 0.02em; text-transform: uppercase;
  line-height: 0.88; margin-bottom: 40px;
}
.bc-title .g { color: var(--gold); }
.bc-sub {
  font-family: 'JetBrains Mono', monospace; font-size: 11px;
  letter-spacing: 0.3em; text-transform: uppercase; color: var(--muted-2);
  margin-bottom: 56px; font-style: italic;
}
.bc-contacts {
  display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-bottom: 40px;
}
.bc-contact {
  font-family: 'JetBrains Mono', monospace; font-size: 9px;
  letter-spacing: 0.18em; text-transform: uppercase; color: var(--muted-2);
  border: 1px solid var(--line); padding: 9px 14px;
}
.bc-contact a { color: inherit; }
.bc-legal {
  max-width: 560px; margin: 0 auto;
  font-size: 11px; color: var(--muted-2); line-height: 1.6;
}

/* ── SECTION LINK NAV ── */
@media (max-width: 900px) {
  .topnav-links { display: none !important; }
}
</style>
</head>

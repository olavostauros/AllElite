<!-- ========================================================
     JAVASCRIPT
     ======================================================== -->
<script is:inline>
(function () {

  // ── SECTIONS ──────────────────────────────────────────
  const SECTIONS = ['cover','ch-brand','ch-logo','ch-color','ch-type','ch-symbols','ch-tiers','ch-bilingual','ch-voice','ch-touch'];

  // ── PROGRESS BAR ──────────────────────────────────────
  const progress = document.getElementById('progress');
  function updateProgress () {
    const scrolled  = window.scrollY;
    const docH = document.documentElement.scrollHeight - window.innerHeight;
    progress.style.width = (docH > 0 ? (scrolled / docH) * 100 : 0) + '%';
  }
  window.addEventListener('scroll', updateProgress, { passive: true });
  updateProgress();

  // ── ACTIVE SECTION ────────────────────────────────────
  const topLinks  = document.querySelectorAll('.topnav-links a');
  const sideItems = document.querySelectorAll('.sidenav-item');

  function setActive (id) {
    topLinks.forEach(a => a.classList.toggle('active', a.dataset.sec === id));
    sideItems.forEach(a => a.classList.toggle('active', a.dataset.sec === id));
  }

  const observer = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) setActive(e.target.id); });
  }, { rootMargin: '-25% 0px -60% 0px', threshold: 0 });

  SECTIONS.forEach(id => {
    const el = document.getElementById(id);
    if (el) observer.observe(el);
  });

  // ── FADE IN ───────────────────────────────────────────
  const fadeEls = document.querySelectorAll('.fade-in');
  const fadeObs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        e.target.classList.add('visible');
        fadeObs.unobserve(e.target);
      }
    });
  }, { rootMargin: '0px 0px -60px 0px', threshold: 0.05 });
  fadeEls.forEach(el => fadeObs.observe(el));

  // ── KEYBOARD NAV ──────────────────────────────────────
  document.addEventListener('keydown', e => {
    if (['ArrowDown','ArrowRight'].includes(e.key)) {
      e.preventDefault();
      const idx = SECTIONS.findIndex(id => {
        const el = document.getElementById(id);
        return el && el.getBoundingClientRect().top > 80;
      });
      if (idx !== -1) document.getElementById(SECTIONS[idx])?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
    if (['ArrowUp','ArrowLeft'].includes(e.key)) {
      e.preventDefault();
      const current = [...SECTIONS].reverse().find(id => {
        const el = document.getElementById(id);
        return el && el.getBoundingClientRect().top < 0;
      });
      if (current) document.getElementById(current)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  });

})();
</script>


<!-- ========================================================
     COVER
     ======================================================== -->
<section id="cover" style="padding-top:64px">
  <div class="cover">
    <div class="cover-grid-bg"></div>
    <div class="cover-ver">VIM v1.0 · Confidential · May 2026</div>
    <div class="container cover-content">
      <div class="cover-doc-label">Visual Identity Manual</div>
      <h1 class="cover-title">All<br><span class="g">Elite</span></h1>
      <p class="cover-sub">Este manual é o registro definitivo das decisões de identidade visual da All Elite. Cada elemento aqui está travado por decisão do Instructor Kemp. Toda aplicação da marca — apparel, digital, sinalização — segue estas páginas.</p>
      <div class="cover-meta">
        <div class="cover-meta-cell">
          <div class="cm-label">Fundador</div>
          <div class="cm-value">Instructor Kemp</div>
        </div>
        <div class="cover-meta-cell">
          <div class="cm-label">Base</div>
          <div class="cm-value">Vila Velha · ES</div>
        </div>
        <div class="cover-meta-cell">
          <div class="cm-label">Versão</div>
          <div class="cm-value">VIM 1.0</div>
        </div>
        <div class="cover-meta-cell">
          <div class="cm-label">Status</div>
          <div class="cm-value" style="color:var(--gold);">Active</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ========================================================
     01 · BRAND FOUNDATION
     ======================================================== -->
<section id="ch-brand" class="chapter">
  <div class="container">

    <div class="chapter-header fade-in">
      <div class="chapter-num">01</div>
      <div class="chapter-title-block">
        <span class="eyebrow">Brand Foundation</span>
        <h2 class="chapter-title">O padrão<br><span class="a">que anda.</span></h2>
        <p class="chapter-lede">A All Elite existe porque um veterano com 82nd Airborne e experiência de combate decidiu que Vila Velha precisava de um padrão diferente. Não um treino. Uma missão.</p>
      </div>
    </div>

    <!-- Mission -->
    <div class="mission-block fade-in">
      <div class="eyebrow">Mission</div>
      <div class="mission-text">Ajudar qualquer pessoa com vontade e determinação a ser<br>a melhor versão de si mesma — desde que faça o trabalho.</div>
    </div>

    <!-- Foundation cards -->
    <div class="foundation-grid fade-in">
      <div class="foundation-card">
        <div class="fc-label">Brand Persona</div>
        <p class="fc-body">O cara que parece intimidante para a maioria das pessoas, mas que é acessível — e sempre disposto a ajudar um estranho. <strong>De longe para o padrão. De perto para o irmão.</strong></p>
      </div>
      <div class="foundation-card">
        <div class="fc-label">Unique Position</div>
        <p class="fc-body">Bootcamp no estilo militar americano, conduzido por um veterano de Spec Ops com experiência de combate. <strong>Não existe outro igual neste mercado.</strong></p>
      </div>
      <div class="foundation-card">
        <div class="fc-label">What We Stand For</div>
        <p class="fc-body">Consistência. Comida real. Sono real. Relacionamentos reais. Treino real. <strong>Transformação lenta através de trabalho de verdade</strong> — anos, não semanas.</p>
      </div>
      <div class="foundation-card">
        <div class="fc-label">What We Stand Against</div>
        <p class="fc-body">Produtos falsos. Motivação vendida. Suplemento como atalho. Promessas rápidas. <strong>A performance de coach-influencer. Tudo que faz um soldado de verdade franzir o cenho.</strong></p>
      </div>
    </div>

    <!-- Pillars -->
    <div class="ch-divider fade-in">
      <div class="ch-divider-line"></div>
      <div class="ch-divider-label">Brand Pillars</div>
      <div class="ch-divider-line"></div>
    </div>

    <div class="pillars-row fade-in">
      <div class="pillar">
        <div class="pillar-num">D</div>
        <div class="pillar-name">Disciplined</div>
        <p class="pillar-desc">Padrão acima de sentimento. Consistência acima de motivação. O treino acontece todos os dias, não quando dá vontade.</p>
      </div>
      <div class="pillar">
        <div class="pillar-num">E</div>
        <div class="pillar-name">Earned</div>
        <p class="pillar-desc">Nada aqui é dado. O tier, a peça de roupa, o respeito — tudo é conquistado. O filtro é parte da marca.</p>
      </div>
      <div class="pillar">
        <div class="pillar-num">B</div>
        <div class="pillar-name">Brotherhood</div>
        <p class="pillar-desc">Quem treina junto vai fundo junto. Não é uma academia. É uma unidade. Vínculos que existem fora da areia.</p>
      </div>
    </div>

    <!-- Voice sliders -->
    <div class="ch-divider fade-in">
      <div class="ch-divider-line"></div>
      <div class="ch-divider-label">Brand Personality — Sliders</div>
      <div class="ch-divider-line"></div>
    </div>

    <div class="voice-sliders fade-in">
      <!-- Serious 4/5 -->
      <div class="slider-row">
        <div class="slider-label-left">Serious</div>
        <div class="slider-track">
          <div class="slider-fill" style="width:80%"></div>
          <div class="slider-thumb" style="left:80%"></div>
        </div>
        <div class="slider-label-right">Playful</div>
      </div>
      <!-- Casual 5/5 -->
      <div class="slider-row">
        <div class="slider-label-left">Formal</div>
        <div class="slider-track">
          <div class="slider-fill" style="width:100%"></div>
          <div class="slider-thumb" style="left:100%"></div>
        </div>
        <div class="slider-label-right">Casual</div>
      </div>
      <!-- Buddy 5/5 -->
      <div class="slider-row">
        <div class="slider-label-left">Expert</div>
        <div class="slider-track">
          <div class="slider-fill" style="width:100%"></div>
          <div class="slider-thumb" style="left:100%"></div>
        </div>
        <div class="slider-label-right">Buddy</div>
      </div>
      <!-- Raw 5/5 -->
      <div class="slider-row">
        <div class="slider-label-left">Refined</div>
        <div class="slider-track">
          <div class="slider-fill" style="width:100%"></div>
          <div class="slider-thumb" style="left:100%"></div>
        </div>
        <div class="slider-label-right">Raw</div>
      </div>
      <!-- Intense 5/5 -->
      <div class="slider-row">
        <div class="slider-label-left">Calm</div>
        <div class="slider-track">
          <div class="slider-fill" style="width:100%"></div>
          <div class="slider-thumb" style="left:100%"></div>
        </div>
        <div class="slider-label-right">Intense</div>
      </div>
    </div>

    <div class="mission-block fade-in" style="margin-top:32px">
      <div class="eyebrow">Voice in One Line</div>
      <div class="mission-text" style="font-size:clamp(18px,3vw,26px)">An 82nd Airborne sergeant who treats you like a brother.</div>
    </div>

